<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.locodrive.ui.SecurityReviewController"
           styleClass="step-root">

    <VBox alignment="TOP_CENTER" spacing="0" maxWidth="700" styleClass="step-card">

        <!-- Header -->
        <VBox styleClass="step-header" spacing="6">
            <Label text="Step 4 of 4" styleClass="step-counter"/>
            <Label text="Security Review" styleClass="step-title"/>
            <Label text="Review your configuration before launching. Make sure you understand the settings below."
                   styleClass="step-subtitle" wrapText="true"/>
        </VBox>

        <!-- Review Body -->
        <ScrollPane fitToWidth="true" styleClass="review-scroll" VBox.vgrow="ALWAYS">
            <VBox styleClass="step-body" spacing="20">

                <!-- Network -->
                <VBox styleClass="review-card" spacing="8">
                    <Label text="🌐  Network" styleClass="review-card-title"/>
                    <Label fx:id="networkSummary" wrapText="true" styleClass="review-card-body"/>
                </VBox>

                <!-- Folders -->
                <VBox styleClass="review-card" spacing="8">
                    <Label text="📁  Shared Folders" styleClass="review-card-title"/>
                    <Label fx:id="folderSummary" wrapText="true" styleClass="review-card-body"/>
                </VBox>

                <!-- Users -->
                <VBox styleClass="review-card" spacing="8">
                    <Label text="👤  User Accounts" styleClass="review-card-title"/>
                    <Label fx:id="userSummary" wrapText="true" styleClass="review-card-body"/>
                </VBox>

                <!-- Guest -->
                <VBox styleClass="review-card" spacing="8">
                    <Label text="🔓  Guest Access" styleClass="review-card-title"/>
                    <Label fx:id="guestSummary" wrapText="true" styleClass="review-card-body"/>
                </VBox>

                <!-- Warnings -->
                <VBox styleClass="review-card warning-card" spacing="10">
                    <Label text="⚠️  Important Notes" styleClass="review-card-title"/>
                    <VBox fx:id="warningBox" spacing="8"/>
                </VBox>

            </VBox>
        </ScrollPane>

        <!-- Launch status -->
        <Label fx:id="launchStatus" text="" styleClass="status-label"
               style="-fx-padding: 8 32 0 32;" wrapText="true"/>

        <!-- Navigation -->
        <HBox styleClass="step-nav" alignment="CENTER_RIGHT" spacing="12">
            <Button text="← Back" styleClass="btn-ghost" onAction="#onBack"/>
            <Button text="🚀 Launch Server" styleClass="btn-success, btn-lg"
                    onAction="#onLaunch"/>
        </HBox>

    </VBox>
</StackPane>
