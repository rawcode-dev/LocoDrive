<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.locodrive.ui.DashboardController"
            styleClass="dashboard-root">

    <!-- ── Top Header ─────────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="dashboard-header" alignment="CENTER_LEFT" spacing="16">
            <Label text="🗄️" styleClass="dash-logo-icon"/>
            <VBox spacing="2">
                <Label text="LocoDrive" styleClass="dash-app-title"/>
                <Label text="Local Network File Server" styleClass="dash-app-sub"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBadge" text="● STOPPED" styleClass="badge-stopped, status-badge"/>
            <Button text="↩ Reconfigure" styleClass="btn-ghost, btn-sm" onAction="#onReconfigure"/>
        </HBox>
    </top>

    <!-- ── Main Content ───────────────────────────────────────────────────── -->
    <center>
        <HBox styleClass="dashboard-body" spacing="0">

            <!-- ── LEFT PANEL: Server Info ─────────────────────────────── -->
            <VBox fx:id="serverInfoPanel" styleClass="dash-left-panel" spacing="24" minWidth="300" maxWidth="340">

                <!-- Server URL Card -->
                <VBox styleClass="dash-card" spacing="12">
                    <Label text="SERVER ADDRESS" styleClass="dash-card-title"/>
                    <Label fx:id="serverUrlLabel" text="—" styleClass="server-url-label" wrapText="true"/>
                    <HBox spacing="8">
                        <Button text="🌐 Open in Browser" styleClass="btn-primary, btn-sm"
                                onAction="#onOpenBrowser" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- QR Code Card -->
                <VBox styleClass="dash-card" spacing="10" alignment="CENTER">
                    <Label text="SCAN QR CODE" styleClass="dash-card-title" alignment="CENTER" maxWidth="Infinity"/>
                    <Label text="Scan with phone to open file browser" styleClass="dash-card-hint"/>
                    <ImageView fx:id="qrCodeView" fitWidth="200" fitHeight="200" preserveRatio="true"/>
                </VBox>

                <!-- Stats Card -->
                <VBox styleClass="dash-card" spacing="14">
                    <Label text="STATISTICS" styleClass="dash-card-title"/>
                    <HBox spacing="20">
                        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4">
                            <Label fx:id="sessionCount" text="0" styleClass="stat-value"/>
                            <Label text="Active Sessions" styleClass="stat-label"/>
                        </VBox>
                        <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="4">
                            <Label fx:id="uptimeLabel" text="00:00:00" styleClass="stat-value"/>
                            <Label text="Uptime" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Start/Stop -->
                <Button fx:id="startStopBtn" text="⏹ Stop Server"
                        styleClass="btn-danger" maxWidth="Infinity"
                        onAction="#onStartStop"/>

            </VBox>

            <!-- ── RIGHT PANEL: Access Log ─────────────────────────────── -->
            <VBox HBox.hgrow="ALWAYS" styleClass="dash-right-panel" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="REAL-TIME ACCESS LOG" styleClass="dash-card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🗑 Clear" styleClass="btn-ghost, btn-sm" onAction="#onClearLog"/>
                </HBox>

                <TextArea fx:id="logArea" styleClass="log-area" VBox.vgrow="ALWAYS"
                          editable="false" wrapText="true"
                          promptText="Access log will appear here when the server starts..."/>

                <HBox styleClass="log-legend" spacing="16" alignment="CENTER_LEFT">
                    <Label text="📂 Browse" styleClass="legend-item"/>
                    <Label text="⬇ Download" styleClass="legend-item"/>
                    <Label text="✅ Login" styleClass="legend-item"/>
                    <Label text="⛔ Failed Auth" styleClass="legend-item"/>
                    <Label text="🚨 Security" styleClass="legend-item"/>
                </HBox>
            </VBox>

        </HBox>
    </center>

</BorderPane>
