<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.locodrive.ui.WelcomeController"
           styleClass="welcome-root">

    <VBox fx:id="rootContainer" alignment="CENTER" spacing="0" maxWidth="560">

        <!-- Logo / Icon -->
        <Label text="🗄️" styleClass="welcome-icon"/>

        <!-- App Name -->
        <Label text="LocoDrive" styleClass="welcome-title"/>

        <!-- Version badge -->
        <HBox alignment="CENTER" spacing="8" style="-fx-padding: 0 0 32 0;">
            <Label text="v1.0" styleClass="version-badge"/>
            <Label text="•" styleClass="subtle"/>
            <Label text="Local Network Only" styleClass="subtle"/>
        </HBox>

        <!-- Tagline (animated) -->
        <Label fx:id="taglineLabel" text="Share files across your home or office network."
               styleClass="welcome-tagline" wrapText="true" textAlignment="CENTER"/>

        <!-- Feature pills -->
        <HBox alignment="CENTER" spacing="12" style="-fx-padding: 32 0 0 0;">
            <Label text="📁 File Browser" styleClass="feature-pill"/>
            <Label text="👤 User Accounts" styleClass="feature-pill"/>
            <Label text="🔒 Secure Login" styleClass="feature-pill"/>
            <Label text="📱 QR Access" styleClass="feature-pill"/>
        </HBox>

        <!-- Buttons -->
        <VBox alignment="CENTER" spacing="12" style="-fx-padding: 48 0 0 0;">
            <Button text="Get Started →" styleClass="btn-primary, btn-lg"
                    onAction="#onGetStarted" maxWidth="260"/>
            <Button text="Load Saved Configuration" styleClass="btn-ghost"
                    onAction="#onLoadConfig" maxWidth="260"/>
        </VBox>

        <!-- Footer -->
        <Label text="Free &amp; Open — Windows and Linux compatible"
               styleClass="welcome-footer" style="-fx-padding: 40 0 0 0;"/>

    </VBox>
</StackPane>
