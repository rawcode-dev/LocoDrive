<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.locodrive.ui.MainController"
            stylesheets="@../css/app.css"
            minWidth="900" minHeight="620">

    <!-- ── Top: Step Indicator ──────────────────────────────────────────── -->
    <top>
        <HBox fx:id="stepIndicator" alignment="CENTER" spacing="12"
              styleClass="step-indicator-bar" visible="false">
            <!-- Dots are built dynamically in MainController.buildStepDots() -->
        </HBox>
    </top>

    <!-- ── Center: Wizard Content Area ─────────────────────────────────── -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" />
    </center>

    <!-- ── Bottom: Navigation Buttons ──────────────────────────────────── -->
    <bottom>
        <HBox fx:id="navBar" styleClass="nav-bar" alignment="CENTER_RIGHT" spacing="12">
            <padding><Insets top="16" right="32" bottom="16" left="32"/></padding>
        </HBox>
    </bottom>

</BorderPane>
