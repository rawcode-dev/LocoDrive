{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocoDrive",
  "version": "1.0.0",
  "identifier": "com.locodrive.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/locodrive-server"
    ],
    "resources": {},
    "windows": {
      "wix": {},
      "nsis": {}
    },
    "linux": {
      "deb": {
        "depends": ["default-jre | java17-runtime | java-runtime"]
      }
    }
  }
}
