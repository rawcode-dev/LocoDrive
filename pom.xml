<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.locodrive</groupId>
    <artifactId>locodrive</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>
    <name>LocoDrive</name>
    <description>A cross-platform local network file sharing server with a beautiful GUI</description>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <javafx.version>21</javafx.version>
    </properties>

    <dependencies>
        <!-- JavaFX Controls -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>
        <!-- JavaFX FXML -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- ZXing QR Code Core -->
        <dependency>
            <groupId>com.google.zxing</groupId>
            <artifactId>core</artifactId>
            <version>3.5.3</version>
        </dependency>

        <!-- JSON for config persistence -->
        <dependency>
            <groupId>org.json</groupId>
            <artifactId>json</artifactId>
            <version>20240303</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- JavaFX Maven Plugin — run with: mvn javafx:run -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <mainClass>com.locodrive.Launcher</mainClass>
                    <jpackageName>LocoDriveServer</jpackageName>
                    <jpackageAppVersion>1.0.0</jpackageAppVersion>
                    <jpackageType>installer</jpackageType>
                    <options>
                        <!-- Memory optimizations to limit RAM usage -->
                        <option>-Xmx128M</option>
                        <option>-XX:+UseSerialGC</option>
                        <option>-XX:MaxRAM=256M</option>
                        <!-- macOS specific -->
                        <option>-Dapple.awt.UIElement=false</option>
                        <option>-Djavafx.macos.interop=true</option>
                        <option>--add-opens=java.desktop/sun.awt=ALL-UNNAMED</option>
                        <option>--add-opens=javafx.graphics/com.sun.javafx.application=ALL-UNNAMED</option>
                        <option>--add-exports=javafx.graphics/com.sun.glass.ui=ALL-UNNAMED</option>
                    </options>
                    <jpackageOptions>
                        <jpackageOption>--runtime-image</jpackageOption>
                        <jpackageOption>${project.build.directory}/custom-jre</jpackageOption>
                    </jpackageOptions>
                </configuration>
            </plugin>

            <!-- Compiler plugin -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <!-- Use release flag instead of source/target to set system modules path -->
                    <release>17</release>
                    <compilerArgs>
                        <arg>-Xlint:unchecked</arg>
                    </compilerArgs>
                </configuration>
            </plugin>


            <!-- GluonFX Plugin to compile Java directly to Native Machine Code via GraalVM -->
            <plugin>
                <groupId>com.gluonhq</groupId>
                <artifactId>gluonfx-maven-plugin</artifactId>
                <version>1.0.29</version>
                <configuration>
                    <mainClass>com.locodrive.Launcher</mainClass>
                    <compilerArgs>
                        <arg>-Os</arg>
                        <arg>--no-fallback</arg>
                        <arg>--enable-http</arg>
                        <arg>--enable-https</arg>
                    </compilerArgs>
                    <reflectionList>
                        <!-- App & Entry Points -->
                        <list>com.locodrive.App</list>
                        <list>com.locodrive.Launcher</list>
                        <list>com.locodrive.AppContext</list>
                        <!-- FXML Controllers (loaded via Class.forName by FXMLLoader) -->
                        <list>com.locodrive.ui.MainController</list>
                        <list>com.locodrive.ui.WelcomeController</list>
                        <list>com.locodrive.ui.NetworkSetupController</list>
                        <list>com.locodrive.ui.FolderSetupController</list>
                        <list>com.locodrive.ui.UserManagementController</list>
                        <list>com.locodrive.ui.SecurityReviewController</list>
                        <list>com.locodrive.ui.DashboardController</list>
                        <list>com.locodrive.ui.BaseStepController</list>
                        <!-- Model classes (used by JSON reflection) -->
                        <list>com.locodrive.model.ServerConfig</list>
                        <list>com.locodrive.model.SharedFolder</list>
                        <list>com.locodrive.model.User</list>
                        <!-- JSON library -->
                        <list>org.json.JSONObject</list>
                        <list>org.json.JSONArray</list>
                        <list>org.json.JSONTokener</list>
                        <!-- ZXing QR (uses reflection internally) -->
                        <list>com.google.zxing.qrcode.QRCodeWriter</list>
                        <list>com.google.zxing.qrcode.decoder.ErrorCorrectionLevel</list>
                    </reflectionList>
                </configuration>
            </plugin>

            <!-- Shade plugin — creates a fat JAR for development testing -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.1</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals><goal>shade</goal></goals>
                        <configuration>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>com.locodrive.Launcher</mainClass>
                                </transformer>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
